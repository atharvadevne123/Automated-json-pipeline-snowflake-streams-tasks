# Snowflake connection
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=REVIEWS_DB
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN    # optional

# Pipeline tuning
PIPELINE_BATCH_SIZE=100    # records per processing chunk
PIPELINE_RETRY_ATTEMPTS=3  # retries for transient failures
PIPELINE_RETRY_BASE_DELAY=1.0  # initial backoff in seconds

# Logging
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR

# AWS (for S3 ingestion)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_PREFIX=reviews/         # key prefix for JSON files

# Output paths (optional)
PIPELINE_OUTPUT_DIR=output/
PIPELINE_METRICS_DIR=output/metrics/
