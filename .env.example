# Snowflake connection settings (required when running pipeline scripts)
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AMAZON_DB
SNOWFLAKE_SCHEMA=DW
SNOWFLAKE_ROLE=SYSADMIN

# AWS S3 settings (required for external stage)
AWS_S3_BUCKET=your-bucket-name
AWS_S3_PREFIX=integration/
AWS_REGION=us-east-1
# IAM role ARN used by Snowflake storage integration
SNOWFLAKE_STORAGE_AWS_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_ROLE
